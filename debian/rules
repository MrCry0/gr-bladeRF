#!/usr/bin/make -f
# Build gr-bladerf using the modern dh sequencer with the cmake
# build system and dh_python3 add-on for the PyBind11 bindings.

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed

%:
	dh $@ --buildsystem=cmake --with python3

override_dh_auto_configure:
	dh_auto_configure -- \
	    -DCMAKE_BUILD_TYPE=RelWithDebInfo \
	    -DENABLE_DOXYGEN=OFF \
	    -DENABLE_PYTHON=ON

# qa_source.py / qa_sink.py require real bladeRF hardware to run, so
# we skip the test phase during package build. Run them manually
# after install if hardware is present.
override_dh_auto_test:

